{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entidad Zelda API",
  "type": "object",
  "properties": {
    "uid": { "type": "string" },
    "id": { "type": "string" },
    "category": { "type": "string" },
    "categoryLabel": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "detailUrl": { "type": "string" },
    "meta": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          { "type": "string" },
          { "type": "string" }
        ],
        "minItems": 2,
        "maxItems": 2
      }
    }
  },
  "required": ["uid", "id", "category", "categoryLabel", "name", "description", "detailUrl", "meta"]
}
